{
  "name": "nextjs-template-mongodb",
  "version": "0.1.0",
  "private": true,
  "description": "A Next.js template for building applications with MongoDB, featuring TypeScript and shadcn/ui / Tailwind CSS integration",
  "author": {
    "name": "Jesse Hall",
    "url": "https://github.com/codeSTACKr"
  },
  "homepage": "https://github.com/thia-sumian-apv/budget-duo-v1#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thia-sumian-apv/budget-duo-v1.git"
  },
  "bugs": {
    "url": "https://github.com/thia-sumian-apv/budget-duo-v1/issues"
  },
  "keywords": [
    "nextjs",
    "mongodb",
    "typescript",
    "tailwindcss",
    "vercel",
    "template",
    "shadcn"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 4001",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "predev": "npm run codegen",
    "prebuild": "npm run codegen",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@apollo/server": "^5.0.0",
    "@as-integrations/next": "^4.1.0",
    "@auth/mongodb-adapter": "^3.11.1",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "@graphql-tools/schema": "^10.0.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.40.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "framer-motion": "^11.2.6",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "lodash": "^4.17.21",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.510.0",
    "mongodb": "^6.3.0",
    "next": "15.1.11",
    "next-auth": "^4.24.12",
    "nodemailer": "^6.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3",
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/near-operation-file-preset": "^3.1.0",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@graphql-codegen/typescript-resolvers": "^5.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
