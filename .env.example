# Local (via docker compose up): mongodb://localhost:27017/budget-duo
# Atlas: mongodb+srv://myDatabaseUser:D1fficultP%40ssw0rd@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/budget-duo

# Sentry error monitoring
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# SMTP (email) — Mailpit catches all mail in dev
# Web UI: http://localhost:8025 | SMTP: localhost:1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@budgetduo.local
# For production (Resend, SES, etc.)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_API_KEY=re_xxxxxxxxxxxx
