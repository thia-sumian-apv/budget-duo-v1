# Local (via docker compose up): mongodb://localhost:27017/budget-duo
# Atlas: mongodb+srv://myDatabaseUser:D1fficultP%40ssw0rd@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/budget-duo

# Sentry error monitoring
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# SMTP (email) — Mailpit catches all mail in dev
# Web UI: http://localhost:8025 | SMTP: localhost:1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@budgetduo.local
# For production (Resend, SES, etc.)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_API_KEY=re_xxxxxxxxxxxx

# App environment (development | staging | production)
# Vercel sets NODE_ENV=production for all deploys, use this to distinguish
NEXT_PUBLIC_APP_ENV=development

# SMTP auth for staging (Mailtrap) or production services
# SMTP_USER=        # Mailtrap username (staging)
# SMTP_PASS=        # Mailtrap password (staging)

# NextAuth
NEXTAUTH_URL=http://localhost:4001
NEXTAUTH_SECRET=
